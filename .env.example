# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/database_name"
DIRECT_URL="postgresql://user:password@localhost:5432/database_name"

# Google OAuth (optional - for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional - for GitHub login)  
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenWeatherMap API
OPENWEATHERMAP_API_KEY=

# Resend Email API
RESEND_API_KEY=
FROM_EMAIL="info@yourcompany.com"

# TCMB Exchange Rates API
TCMB_API_URL=https://api.tcmb.gov.tr/kurlar/today.xml

# Company Info
COMPANY_NAME=YourCompany

# Test Accounts (Development Only)
# Set to false in production to hide test accounts from login page
# Test users will not be seeded in production regardless of this setting
SHOW_TEST_ACCOUNTS=false